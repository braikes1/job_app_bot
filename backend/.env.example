# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/jobbot_db

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OpenAI
OPENAI_API_KEY=sk-...

# AWS S3 / Cloudflare R2 (for resume storage)
S3_BUCKET_NAME=jobbot-resumes
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# LinkedIn session
LINKEDIN_SESSION_FILE=data/linkedin_session.json

# App
APP_ENV=development
CORS_ORIGINS=["http://localhost:3000","https://yourapp.com"]

# Legacy core/ form-filler personal values (used by core/session_handler.py)
GEMINI_API_KEY=your-gemini-api-key-here
USER_EMAIL=you@example.com
USER_FIRST_NAME=First
USER_LAST_NAME=Last
USER_FULL_NAME=First Last
USER_PHONE=555-000-0000
USER_ADDRESS=123 Main St, City, State ZIP
USER_LINKEDIN_URL=https://linkedin.com/in/username
USER_PORTFOLIO_URL=https://yoursite.com
USER_GITHUB_URL=https://github.com/username
USER_DEGREE=B.S.
USER_JOB_TITLE=Software Engineer
USER_CITIZENSHIP=U.S. Citizen
USER_FELONY_STATUS=No
USER_DISABILITY_STATUS=No
